# ─── Runtime ───
MIMMY_ENV=dev
MIMMY_LOG_LEVEL=INFO
MIMMY_DATA_DIR=./data
MIMMY_DB_URL=sqlite:///./data/mimmy.sqlite

# ─── Target ───
# 거래 대상 하나. 시장 코드와 티커 심볼.
MIMMY_MARKET=KR
MIMMY_TICKER=005930   # 삼성전자

# ─── Secrets (운영은 Secrets Manager) ───
MIMMY_USE_SECRETS_MANAGER=false
MIMMY_SECRETS_ID=mimmy/dev
AWS_REGION=ap-northeast-2

# ─── LLM (multi-provider) ───
# 사용할 provider: anthropic | openai | gemini
AI_PROVIDER=anthropic
# 모델명 — 비워두면 provider별 기본값을 쓴다
#   anthropic: claude-opus-4-7
#   openai:    gpt-4o
#   gemini:    gemini-1.5-pro
AI_MODEL=

# API 키 — 사용하는 provider 키만 채우면 된다
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
# 콤마로 여러 ID. 여기에 없는 사용자는 전부 무시된다.
AUTHORIZED_TELEGRAM_IDS=

# ─── Dashboard ───
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8787

# ─── Self-edit ───
# 기본값: PR까지만 생성. main 자동 머지/재기동은 off.
SELF_EDIT_AUTO_MERGE=false
GIT_REMOTE=origin
GIT_BASE_BRANCH=main

# ─── 데이터 소스 ───
# DART: https://opendart.fss.or.kr (무료, 이메일로 발급)
DART_API_KEY=
# 네이버 금융은 키가 없지만 User-Agent 차단 방지를 위해 값 조정 가능
MIMMY_HTTP_USER_AGENT=Mimmy/0.0.1 (+https://localhost)

# ─── Broker 선택 ───
# paper | kis
MIMMY_BROKER=paper

# ─── KIS (한국투자증권) OpenAPI ───
# 환경 선택: paper(모의투자/VTS) | live(실계좌)
KIS_ENV=paper

# 실계좌 자격증명 (KIS_ENV=live 일 때 사용)
KIS_APP_KEY=
KIS_APP_SECRET=
# 계좌번호 — "12345678-01" 또는 10자리 연속(앞 8 + 뒤 2) 모두 허용
KIS_ACCOUNT_NUMBER=

# 모의투자(VTS) 자격증명 (KIS_ENV=paper 일 때 사용)
# apiportal.koreainvestment.com 에서 모의투자 앱 별도 등록 후 입력
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NUMBER=

# KIS 레이트리밋 / 체결폴링 — 연속 주문 에러(초당 건수 초과 등)를 예방한다
KIS_MIN_GAP_SECONDS=0.05
KIS_ORDER_MIN_GAP_SECONDS=0.5
KIS_POLL_INTERVAL_SECONDS=1.0
KIS_POLL_TIMEOUT_SECONDS=60

# ─── US broker (추후) ───
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# ─── Evaluator 루프 ───
# 체결 몇 분 뒤 결과를 평가해 lesson을 뽑을지
EVAL_HORIZON_MINUTES=30
# Trader 프롬프트에 주입할 최근 lesson 개수
EVAL_LESSONS_RECENT=20
# 가상자금 초기값 (paper 모드)
MIMMY_STARTING_CASH=10000000
